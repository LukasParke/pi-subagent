{
  "name": "pi-subagent",
  "version": "0.1.0",
  "description": "Production-grade isolated subagents for the Pi coding agent",
  "type": "module",
  "license": "MIT",
  "author": "Luke Parke",
  "repository": {
    "type": "git",
    "url": "https://github.com/LukasParke/pi-subagent.git"
  },
  "keywords": ["pi-package", "pi-coding-agent", "subagent", "agents", "coding-agent"],
  "files": ["extensions", "src", "README.md", "LICENSE"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm test",
    "pack:check": "npm pack --dry-run"
  },
  "pi": {
    "extensions": ["./extensions/subagent.ts"]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.5",
    "@earendil-works/pi-coding-agent": "^0.80.5",
    "@earendil-works/pi-tui": "^0.80.5",
    "@types/node": "^24.12.0",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": { "node": ">=20" }
}
