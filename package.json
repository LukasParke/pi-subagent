{
  "name": "@parke.dev/pi-subagent",
  "version": "0.3.0",
  "description": "Production-grade isolated subagents for the Pi coding agent",
  "type": "module",
  "license": "MIT",
  "author": "Luke Parke",
  "homepage": "https://github.com/LukasParke/pi-subagent#readme",
  "bugs": {
    "url": "https://github.com/LukasParke/pi-subagent/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LukasParke/pi-subagent.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "subagent",
    "agents",
    "coding-agent",
    "extension",
    "parke.dev"
  ],
  "files": [
    "extensions",
    "src",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm test",
    "pack:check": "npm pack --dry-run",
    "release:check": "npm run check && npm run pack:check"
  },
  "pi": {
    "extensions": [
      "./extensions/subagent.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.7",
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@earendil-works/pi-tui": "^0.80.7",
    "@types/node": "^24.12.0",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
